{
  "name": "@unif/react-native-design",
  "version": "0.9.0",
  "description": "Unif 设计系统:theme + icons + utils + components",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json",
    "./docs-home.css": "./docs-home.css"
  },
  "files": [
    "src",
    "lib",
    "docs-home.css",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/icons/svg",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @unif/react-native-design-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest --passWithNoTests",
    "release": "release-it --only-version"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unif-design/react-native-design.git"
  },
  "author": "unif-design <382724935@qq.com> (https://github.com/unif-design)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/unif-design/react-native-design/issues"
  },
  "homepage": "https://unif-design.github.io/react-native-design/",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.0.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@release-it/conventional-changelog": "^11.0.0",
    "@sbaiahmed1/react-native-blur": "^4.6.2",
    "@types/react": "^19.2.0",
    "commitlint": "^21.0.1",
    "del-cli": "^7.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-reanimated": "^4.4.0",
    "react-native-reanimated-carousel": "^5.0.0-beta.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "0.9.1",
    "release-it": "^20.0.1",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@sbaiahmed1/react-native-blur": ">=4",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": ">=2",
    "react-native-reanimated": ">=4",
    "react-native-reanimated-carousel": ">=5.0.0-beta.0",
    "react-native-safe-area-context": ">=5",
    "react-native-svg": ">=15",
    "react-native-worklets": ">=0.9"
  },
  "workspaces": [
    "example",
    "website"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "testEnvironment": "node",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/website/",
      "<rootDir>/example/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version} [skip ci]",
      "tagName": "v${version}",
      "requireCommits": true
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        },
        "infile": "CHANGELOG.md"
      }
    }
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.62.0"
  }
}
